{
  "name": "@surfaice/next",
  "version": "0.0.4",
  "description": "Next.js middleware for Surfaice \u2014 Accept: text/surfaice runtime serving",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm build"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/surfaiceai/surfaice",
    "directory": "packages/next"
  },
  "dependencies": {
    "@surfaice/format": "workspace:*",
    "@surfaice/react": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "vitest": "^2.0.0",
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
